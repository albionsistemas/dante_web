<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
</head>
<body>
  <p><a href="/admin/artworks">&larr; Obras</a></p>
  <h1><%= artwork ? 'Editar obra' : 'Nueva obra' %></h1>

  <form method="POST" action="<%= action %>" enctype="multipart/form-data">
    <div>
      <label for="title">Título *</label>
      <input type="text" id="title" name="title" value="<%= values.title || '' %>" required />
      <% if (errors.title) { %><p style="color:red;"><%= errors.title[0] %></p><% } %>
    </div>

    <div>
      <label for="artistId">Artista *</label>
      <select id="artistId" name="artistId" required>
        <option value="">-- Elegir --</option>
        <% artists.forEach((artist) => { %>
          <option value="<%= artist.id %>" <%= String(values.artistId) === artist.id ? 'selected' : '' %>>
            <%= artist.name %>
          </option>
        <% }) %>
      </select>
      <% if (errors.artistId) { %><p style="color:red;"><%= errors.artistId[0] %></p><% } %>
    </div>

    <div>
      <label for="description">Descripción</label>
      <textarea id="description" name="description" rows="5"><%= values.description || '' %></textarea>
    </div>

    <div>
      <label for="year">Año</label>
      <input type="number" id="year" name="year" value="<%= values.year || '' %>" />
    </div>

    <div>
      <label for="widthCm">Ancho (cm)</label>
      <input type="number" step="0.01" id="widthCm" name="widthCm" value="<%= values.widthCm || '' %>" />
    </div>
    <div>
      <label for="heightCm">Alto (cm)</label>
      <input type="number" step="0.01" id="heightCm" name="heightCm" value="<%= values.heightCm || '' %>" />
    </div>
    <div>
      <label for="depthCm">Profundidad (cm)</label>
      <input type="number" step="0.01" id="depthCm" name="depthCm" value="<%= values.depthCm || '' %>" />
    </div>

    <div>
      <label for="theme">Tema *</label>
      <select id="theme" name="theme" required>
        <option value="">-- Elegir --</option>
        <% themeOptions.forEach((opt) => { %>
          <option value="<%= opt %>" <%= values.theme === opt ? 'selected' : '' %>><%= opt %></option>
        <% }) %>
      </select>
      <% if (errors.theme) { %><p style="color:red;"><%= errors.theme[0] %></p><% } %>
    </div>

    <div>
      <label for="style">Estilo *</label>
      <select id="style" name="style" required>
        <option value="">-- Elegir --</option>
        <% styleOptions.forEach((opt) => { %>
          <option value="<%= opt %>" <%= values.style === opt ? 'selected' : '' %>><%= opt %></option>
        <% }) %>
      </select>
      <% if (errors.style) { %><p style="color:red;"><%= errors.style[0] %></p><% } %>
    </div>

    <div>
      <label for="technique">Técnica *</label>
      <select id="technique" name="technique" required>
        <option value="">-- Elegir --</option>
        <% techniqueOptions.forEach((opt) => { %>
          <option value="<%= opt %>" <%= values.technique === opt ? 'selected' : '' %>><%= opt %></option>
        <% }) %>
      </select>
      <% if (errors.technique) { %><p style="color:red;"><%= errors.technique[0] %></p><% } %>
    </div>

    <div>
      <label for="support">Soporte</label>
      <input type="text" id="support" name="support" value="<%= values.support || '' %>" placeholder="Lienzo, madera, papel..." />
    </div>

    <div>
      <label for="price">Precio</label>
      <input type="number" step="0.01" id="price" name="price" value="<%= values.price || '' %>" />
    </div>

    <div>
      <label for="discountPercent">Descuento (%)</label>
      <input type="number" step="0.01" min="0" max="100" id="discountPercent" name="discountPercent" value="<%= values.discountPercent || '' %>" />
      <% if (errors.discountPercent) { %><p style="color:red;"><%= errors.discountPercent[0] %></p><% } %>
    </div>

    <div>
      <label>
        <input type="checkbox" name="isPriceOnRequest" <%= values.isPriceOnRequest ? 'checked' : '' %> />
        Precio a consultar
      </label>
    </div>

    <div>
      <label for="status">Estado</label>
      <select id="status" name="status">
        <% statusOptions.forEach((opt) => { %>
          <option value="<%= opt %>" <%= (values.status || 'AVAILABLE') === opt ? 'selected' : '' %>><%= opt %></option>
        <% }) %>
      </select>
    </div>

    <div>
      <label for="deliveryTime">Tiempo de entrega</label>
      <input type="text" id="deliveryTime" name="deliveryTime" value="<%= values.deliveryTime || '' %>" />
    </div>

    <div>
      <label for="paymentMethods">Métodos de pago (separados por coma)</label>
      <input type="text" id="paymentMethods" name="paymentMethods"
        value="<%= Array.isArray(values.paymentMethods) ? values.paymentMethods.join(', ') : (values.paymentMethods || '') %>" />
    </div>

    <div>
      <label for="cost">Costo (uso interno)</label>
      <input type="number" step="0.01" id="cost" name="cost" value="<%= values.cost || '' %>" />
    </div>

    <div>
      <label for="media">
        <%= artwork ? 'Agregar imágenes/videos' : 'Imágenes/videos (podés subir varios, se muestran como slideshow)' %>
      </label>
      <input type="file" id="media" name="media" accept="image/jpeg,image/png,image/webp,video/mp4,video/webm,video/quicktime" multiple />
    </div>

    <button type="submit"><%= artwork ? 'Guardar cambios' : 'Crear obra' %></button>
  </form>

<% if (artwork && artwork.media.length > 0) { %>
    <h2>Slideshow (<%= artwork.media.length %> archivos)</h2>
    <table border="1" cellpadding="8" cellspacing="0">
      <thead>
        <tr>
          <th>Vista previa</th>
          <th>Tipo</th>
          <th>Orden</th>
          <th>Portada</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% artwork.media.forEach((item, index) => { %>
          <tr>
            <td>
              <% if (item.type === 'IMAGE') { %>
                <img src="<%= item.url %>" alt="" width="80" />
              <% } else { %>
                <video src="<%= item.url %>" width="80" muted></video>
              <% } %>
            </td>
            <td><%= item.type %></td>
            <td>
              <% if (index > 0) { %>
                <form method="POST" action="/admin/artworks/<%= artwork.id %>/media/<%= item.id %>/move" style="display:inline">
                  <input type="hidden" name="direction" value="up" />
                  <button type="submit">&uarr;</button>
                </form>
              <% } %>
              <% if (index < artwork.media.length - 1) { %>
                <form method="POST" action="/admin/artworks/<%= artwork.id %>/media/<%= item.id %>/move" style="display:inline">
                  <input type="hidden" name="direction" value="down" />
                  <button type="submit">&darr;</button>
                </form>
              <% } %>
            </td>
            <td>
              <% if (item.isCover) { %>
                Portada
              <% } else { %>
                <form method="POST" action="/admin/artworks/<%= artwork.id %>/media/<%= item.id %>/cover?_method=PUT" style="display:inline">
                  <button type="submit">Hacer portada</button>
                </form>
              <% } %>
            </td>
            <td>
              <form method="POST" action="/admin/artworks/<%= artwork.id %>/media/<%= item.id %>?_method=DELETE" style="display:inline"
                onsubmit="return confirm('¿Eliminar este archivo?')">
                <button type="submit">Eliminar</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <p>El orden de la tabla es el orden del slideshow. Usá las flechas para reordenar.</p>
  <% } %>
</body>
</html>
