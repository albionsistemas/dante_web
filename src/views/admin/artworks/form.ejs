<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../../partials/head', { title }) %>
</head>
<body class="min-h-screen bg-cream font-sans text-ink antialiased">
  <%- include('../../partials/admin-nav') %>

  <main class="mx-auto max-w-3xl px-6 py-12">
    <p><a href="/admin/artworks" class="text-sm uppercase tracking-wider text-ink-soft hover:text-bronze">&larr; Obras</a></p>
    <h1 class="mt-4 font-serif text-3xl text-ink"><%= artwork ? 'Editar obra' : 'Nueva obra' %></h1>

    <% const inputClass = "mt-1 block w-full border border-line bg-white px-3 py-2 text-sm text-ink focus:border-bronze focus:outline-none focus:ring-1 focus:ring-bronze"; %>
    <% const labelClass = "block text-sm font-medium text-ink-soft"; %>

    <form method="POST" action="<%= action %>" enctype="multipart/form-data" class="mt-8 space-y-5">
      <div>
        <label for="title" class="<%= labelClass %>">Título *</label>
        <input type="text" id="title" name="title" value="<%= values.title || '' %>" required class="<%= inputClass %>" />
        <% if (errors.title) { %><p class="mt-1 text-sm text-red-700"><%= errors.title[0] %></p><% } %>
      </div>

      <div>
        <label for="artistId" class="<%= labelClass %>">Artista *</label>
        <select id="artistId" name="artistId" required class="<%= inputClass %>">
          <option value="">-- Elegir --</option>
          <% artists.forEach((artist) => { %>
            <option value="<%= artist.id %>" <%= String(values.artistId) === artist.id ? 'selected' : '' %>>
              <%= artist.name %>
            </option>
          <% }) %>
        </select>
        <% if (errors.artistId) { %><p class="mt-1 text-sm text-red-700"><%= errors.artistId[0] %></p><% } %>
      </div>

      <div>
        <label for="description" class="<%= labelClass %>">Descripción</label>
        <textarea id="description" name="description" rows="4" class="<%= inputClass %>"><%= values.description || '' %></textarea>
      </div>

      <div class="grid grid-cols-4 gap-4">
        <%- include('../../partials/year-field', { id: 'year', name: 'year', label: 'Año', value: values.year, errorList: null }) %>
        <div>
          <label for="widthCm" class="<%= labelClass %>">Ancho (cm)</label>
          <input type="number" step="0.01" id="widthCm" name="widthCm" value="<%= values.widthCm || '' %>" class="<%= inputClass %>" />
        </div>
        <div>
          <label for="heightCm" class="<%= labelClass %>">Alto (cm)</label>
          <input type="number" step="0.01" id="heightCm" name="heightCm" value="<%= values.heightCm || '' %>" class="<%= inputClass %>" />
        </div>
        <div>
          <label for="depthCm" class="<%= labelClass %>">Prof. (cm)</label>
          <input type="number" step="0.01" id="depthCm" name="depthCm" value="<%= values.depthCm || '' %>" class="<%= inputClass %>" />
        </div>
      </div>
      <div class="grid grid-cols-3 gap-4">
        <div>
          <label for="theme" class="<%= labelClass %>">Tema *</label>
          <select id="theme" name="theme" required class="<%= inputClass %>">
            <option value="">-- Elegir --</option>
            <% themeOptions.forEach((opt) => { %>
              <option value="<%= opt %>" <%= values.theme === opt ? 'selected' : '' %>><%= opt %></option>
            <% }) %>
          </select>
          <% if (errors.theme) { %><p class="mt-1 text-sm text-red-700"><%= errors.theme[0] %></p><% } %>
        </div>
        <div>
          <label for="style" class="<%= labelClass %>">Estilo *</label>
          <select id="style" name="style" required class="<%= inputClass %>">
            <option value="">-- Elegir --</option>
            <% styleOptions.forEach((opt) => { %>
              <option value="<%= opt %>" <%= values.style === opt ? 'selected' : '' %>><%= opt %></option>
            <% }) %>
          </select>
          <% if (errors.style) { %><p class="mt-1 text-sm text-red-700"><%= errors.style[0] %></p><% } %>
        </div>
        <div>
          <label for="technique" class="<%= labelClass %>">Técnica *</label>
          <select id="technique" name="technique" required class="<%= inputClass %>">
            <option value="">-- Elegir --</option>
            <% techniqueOptions.forEach((opt) => { %>
              <option value="<%= opt %>" <%= values.technique === opt ? 'selected' : '' %>><%= opt %></option>
            <% }) %>
          </select>
          <% if (errors.technique) { %><p class="mt-1 text-sm text-red-700"><%= errors.technique[0] %></p><% } %>
        </div>
      </div>

      <div>
        <label for="support" class="<%= labelClass %>">Soporte</label>
        <input type="text" id="support" name="support" value="<%= values.support || '' %>" placeholder="Lienzo, madera, papel..." class="<%= inputClass %>" />
      </div>

      <div class="border-t border-line pt-5">
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label for="price" class="<%= labelClass %>">Precio</label>
            <input type="number" step="0.01" id="price" name="price" value="<%= values.price || '' %>" class="<%= inputClass %>" />
          </div>
          <div>
            <label for="discountPercent" class="<%= labelClass %>">Descuento (%)</label>
            <input type="number" step="0.01" min="0" max="100" id="discountPercent" name="discountPercent" value="<%= values.discountPercent || '' %>" class="<%= inputClass %>" />
            <% if (errors.discountPercent) { %><p class="mt-1 text-sm text-red-700"><%= errors.discountPercent[0] %></p><% } %>
          </div>
          <div>
            <label for="status" class="<%= labelClass %>">Estado</label>
            <select id="status" name="status" class="<%= inputClass %>">
              <% statusOptions.forEach((opt) => { %>
                <option value="<%= opt %>" <%= (values.status || 'AVAILABLE') === opt ? 'selected' : '' %>><%= opt %></option>
              <% }) %>
            </select>
          </div>
        </div>
        <label class="mt-3 flex items-center gap-2 text-sm text-ink-soft">
          <input type="checkbox" name="isPriceOnRequest" <%= values.isPriceOnRequest ? 'checked' : '' %> class="border-line" />
          Precio a consultar
        </label>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="deliveryTime" class="<%= labelClass %>">Tiempo de entrega</label>
          <input type="text" id="deliveryTime" name="deliveryTime" value="<%= values.deliveryTime || '' %>" class="<%= inputClass %>" />
        </div>
        <div>
          <label for="paymentMethods" class="<%= labelClass %>">Métodos de pago (separados por coma)</label>
          <input type="text" id="paymentMethods" name="paymentMethods"
            value="<%= Array.isArray(values.paymentMethods) ? values.paymentMethods.join(', ') : (values.paymentMethods || '') %>" class="<%= inputClass %>" />
        </div>
      </div>

      <div>
        <label for="cost" class="<%= labelClass %>">Costo (uso interno)</label>
        <input type="number" step="0.01" id="cost" name="cost" value="<%= values.cost || '' %>" class="<%= inputClass %>" />
      </div>

      <div class="border-t border-line pt-5">
        <label for="media" class="<%= labelClass %>">
          <%= artwork ? 'Agregar imágenes/videos' : 'Imágenes/videos (podés subir varios, se muestran como slideshow)' %>
        </label>
        <input type="file" id="media" name="media" accept="image/jpeg,image/png,image/webp,video/mp4,video/webm,video/quicktime" multiple class="mt-1 block w-full text-sm text-ink-soft" />
      </div>

      <button type="submit" class="bg-ink px-5 py-2.5 text-sm uppercase tracking-wider text-cream hover:bg-bronze-dark">
        <%= artwork ? 'Guardar cambios' : 'Crear obra' %>
      </button>
    </form>
    <% if (artwork && artwork.media.length > 0) { %>
      <h2 class="mt-14 font-serif text-2xl text-ink">Slideshow (<%= artwork.media.length %> archivos)</h2>
      <table class="mt-6 w-full border-collapse text-left text-sm">
        <thead>
          <tr class="border-b border-line text-xs uppercase tracking-wider text-ink-soft">
            <th class="py-3 pr-4 font-medium">Vista previa</th>
            <th class="py-3 pr-4 font-medium">Tipo</th>
            <th class="py-3 pr-4 font-medium">Orden</th>
            <th class="py-3 pr-4 font-medium">Portada</th>
            <th class="py-3"></th>
          </tr>
        </thead>
        <tbody>
          <% artwork.media.forEach((item, index) => { %>
            <tr class="border-b border-line">
              <td class="py-3 pr-4">
                <% if (item.type === 'IMAGE') { %>
                  <img src="<%= item.thumbnailUrl || item.url %>" alt="" class="h-16 w-16 object-cover" />
                <% } else { %>
                  <video src="<%= item.url %>" class="h-16 w-16 object-cover" muted></video>
                <% } %>
              </td>
              <td class="py-3 pr-4 text-ink-soft"><%= item.type %></td>
              <td class="py-3 pr-4">
                <% if (index > 0) { %>
                  <form method="POST" action="/admin/artworks/<%= artwork.id %>/media/<%= item.id %>/move" class="inline">
                    <input type="hidden" name="direction" value="up" />
                    <button type="submit" class="border border-line px-2 py-1 hover:border-bronze">&uarr;</button>
                  </form>
                <% } %>
                <% if (index < artwork.media.length - 1) { %>
                  <form method="POST" action="/admin/artworks/<%= artwork.id %>/media/<%= item.id %>/move" class="ml-1 inline">
                    <input type="hidden" name="direction" value="down" />
                    <button type="submit" class="border border-line px-2 py-1 hover:border-bronze">&darr;</button>
                  </form>
                <% } %>
              </td>
              <td class="py-3 pr-4">
                <% if (item.isCover) { %>
                  <span class="text-xs uppercase tracking-wider text-bronze-dark">Portada</span>
                <% } else { %>
                  <form method="POST" action="/admin/artworks/<%= artwork.id %>/media/<%= item.id %>/cover?_method=PUT" class="inline">
                    <button type="submit" class="text-bronze-dark hover:underline">Hacer portada</button>
                  </form>
                <% } %>
              </td>
              <td class="py-3">
                <form method="POST" action="/admin/artworks/<%= artwork.id %>/media/<%= item.id %>?_method=DELETE" class="inline"
                  onsubmit="return confirm('¿Eliminar este archivo?')">
                  <button type="submit" class="text-red-700 hover:underline">Eliminar</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <p class="mt-3 text-xs text-ink-soft">El orden de la tabla es el orden del slideshow. Usá las flechas para reordenar.</p>
    <% } %>
  </main>

  <%- include('../../partials/year-picker-script') %>
</body>
</html>
