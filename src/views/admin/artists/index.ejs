<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
</head>
<body>
  <p><a href="/admin">&larr; Panel</a></p>
  <h1>Artistas</h1>

  <% if (error) { %>
    <p style="color: red;"><%= error %></p>
  <% } %>

  <p><a href="/admin/artists/new">+ Nuevo artista</a></p>

  <% if (artists.length === 0) { %>
    <p>Todavía no hay artistas cargados.</p>
  <% } else { %>
    <table border="1" cellpadding="8" cellspacing="0">
      <thead>
        <tr>
          <th>Foto</th>
          <th>Nombre</th>
          <th>Nacionalidad</th>
          <th>Años</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% artists.forEach((artist) => { %>
          <tr>
            <td>
              <% if (artist.photoUrl) { %>
                <img src="<%= artist.photoUrl %>" alt="<%= artist.name %>" width="60" />
              <% } %>
            </td>
            <td><%= artist.name %></td>
            <td><%= artist.nationality || '—' %></td>
            <td><%= artist.birthYear || '?' %>–<%= artist.deathYear || '' %></td>
            <td>
              <a href="/admin/artists/<%= artist.id %>/edit">Editar</a>
              <form method="POST" action="/admin/artists/<%= artist.id %>?_method=DELETE" style="display:inline"
                onsubmit="return confirm('¿Eliminar a <%= artist.name %>?')">
                <button type="submit">Eliminar</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</body>
</html>
