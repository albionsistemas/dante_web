<% const cover = artwork.media && artwork.media[0]; %>
<a href="/obras/<%= artwork.slug %>" class="group block">
  <div class="aspect-[4/5] overflow-hidden bg-cream-dark">
    <% if (cover && cover.type === 'IMAGE') { %>
      <img src="<%= cover.url %>" alt="<%= artwork.title %>" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
    <% } else if (cover && cover.type === 'VIDEO') { %>
      <video src="<%= cover.url %>" class="h-full w-full object-cover" muted></video>
    <% } %>
  </div>
  <div class="mt-3 space-y-1">
    <h3 class="font-serif text-lg text-ink"><%= artwork.title %></h3>
    <p class="text-sm text-ink-soft"><%= artwork.artist.name %></p>
    <p class="text-sm">
      <% if (artwork.isPriceOnRequest) { %>
        <span class="text-ink-soft">Precio a consultar</span>
      <% } else if (artwork.price) { %>
        <% if (artwork.status === 'ON_SALE' && artwork.discountPercent) { %>
          <span class="text-ink-soft line-through">$<%= artwork.price %></span>
          <span class="font-medium text-bronze-dark">$<%= (Number(artwork.price) * (1 - Number(artwork.discountPercent) / 100)).toFixed(2) %></span>
        <% } else { %>
          <span class="text-ink">$<%= artwork.price %></span>
        <% } %>
      <% } %>
      <% if (artwork.status === 'SOLD') { %><span class="ml-2 text-xs uppercase tracking-wide text-ink-soft">Vendida</span><% } %>
      <% if (artwork.status === 'RESERVED') { %><span class="ml-2 text-xs uppercase tracking-wide text-ink-soft">Reservada</span><% } %>
      <% if (artwork.status === 'ON_SALE') { %><span class="ml-2 text-xs uppercase tracking-wide text-bronze-dark">Oferta</span><% } %>
    </p>
  </div>
</a>
