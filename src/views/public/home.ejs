<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head', { title }) %>
</head>
<body class="bg-cream font-sans text-ink antialiased">
  <%- include('../partials/nav') %>

  <main>
    <section class="mx-auto max-w-6xl px-6 py-20 text-center">
      <h1 class="font-serif text-4xl text-ink sm:text-5xl">Obra plástica</h1>
      <p class="mx-auto mt-4 max-w-xl text-ink-soft">
        Una selección curada de pinturas y obras originales.
      </p>
      <a href="/obras" class="mt-8 inline-block border border-ink px-6 py-2.5 text-sm uppercase tracking-wider text-ink transition hover:bg-ink hover:text-cream">
        Ver toda la galería
      </a>
    </section>

    <% if (artworks.length > 0) { %>
      <section class="mx-auto max-w-6xl px-6 pb-24">
        <div class="grid grid-cols-2 gap-x-8 gap-y-12 sm:grid-cols-3">
          <% artworks.forEach((artwork) => { %>
            <%- include('../partials/artwork-card', { artwork }) %>
          <% }) %>
        </div>
      </section>
    <% } %>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
