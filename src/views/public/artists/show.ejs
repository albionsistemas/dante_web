<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
</head>
<body>
  <p><a href="/artistas">&larr; Artistas</a></p>

  <div style="display:flex; gap:24px; align-items:flex-start;">
    <% if (artist.photoUrl) { %>
      <img src="<%= artist.photoUrl %>" alt="<%= artist.name %>" width="200" />
    <% } %>
    <div>
      <h1><%= artist.name %></h1>
      <p>
        <% if (artist.nationality) { %><%= artist.nationality %><% } %>
        <% if (artist.birthYear) { %>
          <% if (artist.nationality) { %> — <% } %>
          <%= artist.birthYear %>–<%= artist.deathYear || '' %>
        <% } %>
      </p>

      <% if (artist.bio) { %>
        <p><%= artist.bio %></p>
      <% } %>

      <p>
        <% if (artist.website) { %>
          <a href="<%= artist.website %>" target="_blank" rel="noopener noreferrer">Sitio web</a>
        <% } %>
        <% if (artist.instagram) { %>
          <a href="https://instagram.com/<%= artist.instagram.replace(/^@/, '') %>" target="_blank" rel="noopener noreferrer">Instagram</a>
        <% } %>
      </p>
    </div>
  </div>

  <h2>Obras</h2>
  <% if (artist.artworks.length === 0) { %>
    <p>Todavía no hay obras publicadas de este artista.</p>
  <% } else { %>
    <div style="display:flex; flex-wrap:wrap; gap:16px;">
      <% artist.artworks.forEach((artwork) => { %>
        <% const cover = artwork.media[0]; %>
        <a href="/obras/<%= artwork.slug %>" style="width:180px; text-decoration:none; color:inherit;">
          <% if (cover && cover.type === 'IMAGE') { %>
            <img src="<%= cover.url %>" alt="<%= artwork.title %>" width="180" />
          <% } else if (cover && cover.type === 'VIDEO') { %>
            <video src="<%= cover.url %>" width="180" muted></video>
          <% } %>
          <p><%= artwork.title %></p>
        </a>
      <% }) %>
    </div>
  <% } %>
</body>
</html>
