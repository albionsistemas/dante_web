<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../../partials/head', { title }) %>
</head>
<body class="bg-cream font-sans text-ink antialiased">
  <%- include('../../partials/nav') %>

  <main class="mx-auto max-w-6xl px-6 py-12">
    <a href="/artistas" class="text-sm uppercase tracking-wider text-ink-soft hover:text-bronze">&larr; Artistas</a>

    <div class="mt-6 flex flex-col gap-8 sm:flex-row sm:items-start">
      <% if (artist.photoUrl) { %>
        <img src="<%= artist.photoUrl %>" alt="<%= artist.name %>" class="h-48 w-48 flex-shrink-0 rounded-full object-cover" />
      <% } %>
      <div>
        <h1 class="font-serif text-3xl text-ink"><%= artist.name %></h1>
        <p class="mt-1 text-ink-soft">
          <% if (artist.nationality) { %><%= artist.nationality %><% } %>
          <% if (artist.birthYear) { %>
            <% if (artist.nationality) { %> &middot; <% } %>
            <%= artist.birthYear %>–<%= artist.deathYear || '' %>
          <% } %>
        </p>

        <% if (artist.bio) { %>
          <p class="mt-4 max-w-2xl leading-relaxed text-ink-soft"><%= artist.bio %></p>
        <% } %>

        <p class="mt-4 flex gap-4 text-sm">
          <% if (artist.website) { %>
            <a href="<%= artist.website %>" target="_blank" rel="noopener noreferrer" class="text-bronze-dark hover:underline">Sitio web</a>
          <% } %>
          <% if (artist.instagram) { %>
            <a href="https://instagram.com/<%= artist.instagram.replace(/^@/, '') %>" target="_blank" rel="noopener noreferrer" class="text-bronze-dark hover:underline">Instagram</a>
          <% } %>
        </p>
      </div>
    </div>

    <h2 class="mt-16 font-serif text-2xl text-ink">Obras</h2>
    <% if (artist.artworks.length === 0) { %>
      <p class="mt-4 text-ink-soft">Todavía no hay obras publicadas de este artista.</p>
    <% } else { %>
      <div class="mt-8 grid grid-cols-2 gap-x-8 gap-y-12 sm:grid-cols-3">
        <% artist.artworks.forEach((artwork) => { %>
          <%- include('../../partials/artwork-card', { artwork: { ...artwork, artist } }) %>
        <% }) %>
      </div>
    <% } %>
  </main>

  <%- include('../../partials/footer') %>
</body>
</html>
