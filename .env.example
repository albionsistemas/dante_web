NODE_ENV=development
PORT=3000

# PostgreSQL 18 local (instalado nativamente, sin Docker)
DATABASE_URL="postgresql://dante:dante_dev_password@localhost:5432/dante_web?schema=public"

# Autenticación
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Cookies de sesión
COOKIE_SECRET="change-me-too"

# Admin seedeado (opcional, ver prisma/seed.ts para los valores por defecto)
SEED_ADMIN_EMAIL="admin@dante.local"
SEED_ADMIN_PASSWORD="change-me-123"
SEED_ADMIN_NAME="Admin ArteReal"
